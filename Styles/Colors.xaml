<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors - Muted Grey-Green Theme -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#5A7B6A"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#4A6B5A"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#7B9A8A"/>
    
    <!-- Background Colors - Dark Theme -->
    <SolidColorBrush x:Key="LightBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="DarkBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#3A3A3A"/>
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="BlackBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="#C0C0C0"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#E0E0E0"/>
    
    <!-- Gray Scale - Dark Theme -->
    <SolidColorBrush x:Key="Gray100Brush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="#4A4A4A"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="#5A5A5A"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="#7A7A7A"/>
    <SolidColorBrush x:Key="Gray700Brush" Color="#8A8A8A"/>
    <SolidColorBrush x:Key="Gray800Brush" Color="#9A9A9A"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="#BABABA"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4A6B5A"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#8B6B3A"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#8B4A4A"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#4A6B8B"/>

</ResourceDictionary>
