<Window x:Class="MeetingNotesApp.NoteTakingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Notes - Taking Notes" Height="700" Width="900"
        Background="{DynamicResource LightBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource PrimaryBrush}" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="{DynamicResource WhiteBrush}" Margin="0,0,15,0"/>
                <TextBlock Text="Recording Meeting Notes" 
                           Foreground="{DynamicResource WhiteBrush}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding MeetingTitle}" 
                           Foreground="{DynamicResource AccentBrush}" 
                           FontSize="14" 
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                
                <!-- Meeting Info -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Meeting Information" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Title:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MeetingTitle}" Margin="0,0,0,5" FontSize="14" Padding="8,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Organizer:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MeetingOrganizer}" Margin="0,0,0,5" FontSize="14" Padding="8,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Attendees:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MeetingAttendees}" Margin="0,0,0,5" FontSize="14" Padding="8,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Database:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DatabaseInfo}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Started:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MeetingStartTime}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Duration:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding MeetingDuration}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Status:" FontWeight="Bold" Margin="0,0,10,0"/>
                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{Binding TranscriptionStatusColor}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding TranscriptionStatus}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Live Transcription -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Live Transcription" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Margin="0,0,10,0"/>
                            <Ellipse Width="8" Height="8" 
                                    Fill="{Binding TranscriptionStatusColor}" 
                                    Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding TranscriptionStatus}" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,20,0"/>
                            <Button Content="{Binding RecordingButtonText}" 
                                    Click="OnToggleRecordingClicked"
                                    Padding="12,6"
                                    Background="{Binding RecordingButtonColor}"
                                    MinWidth="100"/>
                        </StackPanel>
                        
                        <ScrollViewer Height="150">
                            <TextBlock Text="{Binding LiveTranscription}" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Manual Notes -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Your Notes" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,5"/>
                        
                        <TextBlock Text="Add your own notes alongside the transcription. These will be saved to a separate field in Notion." 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontStyle="Italic"
                                   Margin="0,0,0,10"/>
                        
                        <TextBox Text="{Binding ManualNotes}" 
                                 Height="200" 
                                 FontSize="14"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>

                <!-- AI Summary -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="AI Summary" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,5"/>
                        
                        <TextBlock Text="Generate an AI-powered summary of the meeting transcription and notes." 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontStyle="Italic"
                                   Margin="0,0,0,10"/>
                        
                        <TextBox Text="{Binding AiSummary}" 
                                 Height="150" 
                                 FontSize="14"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource BackgroundBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Key Points -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Key Points" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <ListBox x:Name="KeyPointsListBox" Height="120" Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsCompleted}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Text}" 
                                                   VerticalAlignment="Center" 
                                                   FontSize="14"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="NewKeyPointBox" 
                                     Width="300" 
                                     Margin="0,0,10,0"/>
                            <Button Content="Add" 
                                    Click="OnAddKeyPointClicked" 
                                    Padding="15,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Action Items -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="Action Items" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <ListBox x:Name="ActionItemsListBox" Height="120" Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsCompleted}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Text}" 
                                                   VerticalAlignment="Center" 
                                                   FontSize="14" 
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Assignee}" 
                                                   FontSize="12" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="NewActionItemBox" 
                                     Width="300" 
                                     Margin="0,0,10,0"/>
                            <Button Content="Add" 
                                    Click="OnAddActionItemClicked" 
                                    Padding="15,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Actions -->
        <Border Grid.Row="2" 
                Background="{DynamicResource SurfaceBrush}" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Stop Recording" 
                        Background="{DynamicResource Gray600Brush}" 
                        Foreground="White"
                        Click="OnStopRecordingClicked" 
                        Padding="15,8"
                        Margin="0,0,15,0"/>
                <Button Content="Save to Notion" 
                        Background="{DynamicResource PrimaryBrush}" 
                        Foreground="White"
                        Click="OnSaveToNotionClicked" 
                        Padding="15,8"
                        Margin="0,0,15,0"/>
                <Button Content="Generate Summary" 
                        Background="{DynamicResource PrimaryDarkBrush}" 
                        Foreground="White"
                        Click="OnGenerateSummaryClicked" 
                        Padding="15,8"/>
            </StackPanel>
        </Border>

    </Grid>

</Window>