<Window x:Class="MeetingNotesApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Notes" Height="800" Width="1000"
        Background="{DynamicResource LightBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,15,20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource WhiteBrush}" Margin="0,0,15,0"/>
                    <TextBlock Text="Meeting Notes" 
                               Foreground="{DynamicResource WhiteBrush}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <Button Grid.Column="1"
                        Click="OnOpenSettingsClicked"
                        Style="{StaticResource IconButtonStyle}"
                        Padding="2"
                        Width="40"
                        Height="40"
                        ToolTip="Settings"
                        Margin="0,0,0,0">
                    <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.22,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                          Fill="{DynamicResource WhiteBrush}" 
                          Width="24" 
                          Height="24"/>
                </Button>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" 
                CornerRadius="0" 
                Padding="20,10"
                BorderBrush="{DynamicResource Gray300Brush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding StatusText}" 
                           FontSize="14" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock Text="{Binding StatusDescription}" 
                           FontSize="12" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" Padding="20">
            <StackPanel>

                <!-- Start a Meeting Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="10"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Start a Meeting" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Not Connected State (no integrations configured) -->
                        <StackPanel x:Name="NotConnectedPanel">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasIntegrations}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Get Started"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Choose where to save your meeting notes — Notion, CSV, Excel, and more."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,15"/>

                            <Button Content="Add Integration"
                                    Click="OnAddIntegrationClicked"
                                    Padding="20,12"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>

                        <!-- Connected State (integrations available) -->
                        <StackPanel x:Name="ConnectedPanel">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasIntegrations}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- Connection status indicator -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Ellipse Width="8" Height="8"
                                         Fill="{DynamicResource SuccessBrush}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ConnectionStatusText}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ConnectedIntegrationSummary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Integration selector dropdown -->
                            <TextBlock Text="Save notes to:"
                                       FontSize="14"
                                       Margin="0,0,0,6"/>

                            <ComboBox x:Name="IntegrationComboBox"
                                      Height="35"
                                      FontSize="14"
                                      TextElement.Foreground="#000000"
                                      Margin="0,0,0,4"
                                      SelectionChanged="OnIntegrationSelectionChanged">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#000000"/>
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{Binding StatusColor}"
                                                    CornerRadius="3"
                                                    Padding="5,2"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ProviderDisplayName}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Foreground="#000000" VerticalAlignment="Center">
                                                <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                                                <Run Text=" — " Foreground="#888888"/>
                                                <Run Text="{Binding TargetDescription, Mode=OneWay}" Foreground="#666666"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Validation error message (hidden by default) -->
                            <TextBlock x:Name="ValidationErrorText"
                                       Text="Please select where to save your meeting notes"
                                       FontSize="12"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       Visibility="Collapsed"
                                       Margin="0,4,0,8"/>

                            <!-- Spacer when no error -->
                            <Border x:Name="DropdownSpacer" Height="11"/>

                            <!-- Start Meeting button -->
                            <Button Content="Start Meeting"
                                    Click="OnStartNotesClicked"
                                    Padding="20,12"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Test Section -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Test Functions" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Scan Now"
                                    Click="OnSimulateCallClicked"
                                    Padding="15,8"
                                    Margin="0,0,10,0"/>
                            <Button Content="Test Notion Connection"
                                    Click="OnTestNotionClicked"
                                    IsEnabled="{Binding HasIntegrations}"
                                    Padding="15,8"
                                    Margin="0,0,10,0"/>
                            <Button Content="Start New Meeting"
                                    Click="OnStartNotesClicked"
                                    Padding="15,8"
                                    Margin="0,0,10,0"/>
                            <Button Content="Test LLamaSharp"
                                    Click="OnTestLLamaSharpClicked"
                                    Padding="15,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Call Detection Result Banner -->
                <Border CornerRadius="10"
                        Padding="20"
                        Margin="0,0,0,20"
                        BorderThickness="2"
                        BorderBrush="{Binding DetectionBannerColor}"
                        Background="{DynamicResource SurfaceElevatedBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDetectionBannerVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <!-- Header: status dot + title + dismiss button -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0"
                                     Width="16" Height="16"
                                     Fill="{Binding DetectionBannerColor}"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding DetectionBannerTitle}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="2"
                                    Content="✕"
                                    Click="OnDismissDetectionBanner"
                                    Style="{StaticResource IconButtonStyle}"
                                    Padding="8,4"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    ToolTip="Dismiss"/>
                        </Grid>

                        <!-- Detail message -->
                        <TextBlock Text="{Binding DetectionBannerMessage}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="28,0,0,0"/>

                        <!-- "Start Taking Notes" button (only when apps found) -->
                        <StackPanel Margin="28,15,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DetectionFoundApps}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button Content="Start Taking Notes"
                                    Click="OnStartNotesFromDetection"
                                    Padding="20,12"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Recent Notes -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="10"
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="Recent Notes" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <ListBox x:Name="RecentNotesListBox" Height="150" SelectionChanged="OnRecentNoteClicked">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource LightBrush}" 
                                            CornerRadius="5" 
                                            Padding="10" 
                                            Margin="0,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" 
                                                       FontSize="14" 
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Date}" 
                                                       FontSize="12" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Preview}" 
                                                       FontSize="12" 
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</Window>
