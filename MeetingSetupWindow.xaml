<Window x:Class="MeetingNotesApp.MeetingSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Notes - Setup" Height="500" Width="600"
        Background="{DynamicResource LightBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="{DynamicResource WhiteBrush}" Margin="0,0,15,0"/>
                <TextBlock Text="Setup Meeting Notes" 
                           Foreground="{DynamicResource WhiteBrush}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="Configure meeting details and select workspace" 
                           Foreground="{DynamicResource AccentBrush}" 
                           FontSize="12" 
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>

                <!-- Workspace Selection -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Select Workspace" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Choose which workspace to save your meeting notes to:" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,10"/>
                        
                        <ComboBox x:Name="WorkspaceComboBox" 
                                  ItemsSource="{Binding AvailableWorkspaces}"
                                  DisplayMemberPath="WorkspaceName"
                                  SelectedItem="{Binding SelectedWorkspace}"
                                  Height="35"
                                  FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- Meeting Information -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="Meeting Information" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Date -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Date:" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                            <DatePicker Grid.Row="0" Grid.Column="1" 
                                        SelectedDate="{Binding MeetingDate}"
                                        Margin="0,0,0,10"/>

                            <!-- Title -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Title:" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                            <TextBox Grid.Row="1" Grid.Column="1" 
                                     Text="{Binding MeetingTitle}"
                                     Margin="0,0,0,10"/>

                            <!-- Organizer -->
                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                       Text="Organizer:" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                            <TextBox Grid.Row="2" Grid.Column="1" 
                                     Text="{Binding MeetingOrganizer}"
                                     Margin="0,0,0,10"/>

                            <!-- Attendees -->
                            <TextBlock Grid.Row="3" Grid.Column="0" 
                                       Text="Attendees:" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                            <TextBox Grid.Row="3" Grid.Column="1" 
                                     Text="{Binding MeetingAttendees}"
                                     Margin="0,0,0,10"
                                     ToolTip="Enter attendees separated by commas"/>

                            <!-- Comments -->
                            <TextBlock Grid.Row="4" Grid.Column="0" 
                                       Text="Comments:" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Top"
                                       Margin="0,0,10,10"/>
                            <TextBox Grid.Row="4" Grid.Column="1" 
                                     Text="{Binding MeetingComments}"
                                     Height="60"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Actions -->
        <Border Grid.Row="2" 
                Background="{DynamicResource SurfaceBrush}" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" 
                        Background="{DynamicResource Gray600Brush}" 
                        Foreground="White"
                        Click="OnCancelClicked" 
                        Padding="15,8"
                        Margin="0,0,10,0"/>
                <Button Content="Start Taking Notes" 
                        Background="{DynamicResource PrimaryBrush}" 
                        Foreground="White"
                        Click="OnStartNotesClicked" 
                        Padding="15,8"/>
            </StackPanel>
        </Border>

    </Grid>

</Window>
