<Window x:Class="MeetingNotesApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Notes - Settings" Height="700" Width="900"
        Background="{DynamicResource LightBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="{DynamicResource WhiteBrush}" Margin="0,0,15,0"/>
                <TextBlock Text="Settings" 
                           Foreground="{DynamicResource WhiteBrush}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="Manage integrations and preferences" 
                           Foreground="{DynamicResource AccentBrush}" 
                           FontSize="14" 
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>

                <!-- Notion Workspace Integrations -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Notion Workspace Integrations" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Margin="0,0,10,0"/>
                            <Button Content="Add Workspace" 
                                    Click="OnAddWorkspaceClicked" 
                                    Padding="15,8"
                                    Background="{DynamicResource SuccessBrush}"/>
                        </StackPanel>
                        
                        <TextBlock Text="Manage your Notion workspace integrations. Each workspace requires its own API key." 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- Workspace List -->
                        <ListBox x:Name="WorkspaceListBox" 
                                 Height="300" 
                                 Margin="0,0,0,15"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,10"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource LightBrush}" 
                                            CornerRadius="8" 
                                            Padding="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding WorkspaceName}" 
                                                           FontSize="16" 
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding WorkspaceId}" 
                                                           FontSize="12" 
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding SelectedDatabase.Name}" 
                                                           FontSize="12" 
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,0,0,5"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" 
                                                            Fill="{Binding StatusColor}" 
                                                            Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding StatusText}" 
                                                               FontSize="12" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="Edit" 
                                                        Click="OnEditWorkspaceClicked" 
                                                        Tag="{Binding}"
                                                        Padding="12,6"
                                                        Margin="0,0,5,0"
                                                        FontSize="12"
                                                        MinWidth="50"
                                                        Background="{DynamicResource InfoBrush}"/>
                                                <Button Content="Test" 
                                                        Click="OnTestWorkspaceClicked" 
                                                        Tag="{Binding}"
                                                        Padding="12,6"
                                                        Margin="0,0,5,0"
                                                        FontSize="12"
                                                        MinWidth="50"
                                                        Background="{DynamicResource PrimaryBrush}"/>
                                                <Button Content="Delete" 
                                                        Click="OnDeleteWorkspaceClicked" 
                                                        Tag="{Binding}"
                                                        Padding="12,6"
                                                        FontSize="12"
                                                        MinWidth="60"
                                                        Background="{DynamicResource ErrorBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Add/Edit Workspace Form -->
                        <Border Background="{DynamicResource LightBrush}" 
                                CornerRadius="8" 
                                Padding="15">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFormVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding FormTitle}" 
                                           FontSize="16" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,15"/>
                                
                                <TextBlock Text="Workspace Display Name" 
                                           FontSize="14" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="WorkspaceNameBox" 
                                         Text="{Binding EditingWorkspace.WorkspaceName}"
                                         Margin="0,0,0,15"
                                         ToolTip="This is the name you'll see when selecting where to save notes"/>
                                
                                <TextBlock Text="Notion API Key" 
                                           FontSize="14" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="ApiKeyBox" Grid.Column="0"/>
                                    <Button Content="Fetch Databases" 
                                            Grid.Column="2"
                                            Click="OnFetchDatabasesClicked"
                                            Padding="15,8"
                                            Background="{DynamicResource PrimaryBrush}"
                                            ToolTip="Click to retrieve databases from Notion"/>
                                </Grid>
                                
                                <TextBlock Text="Meeting Notes Database" 
                                           FontSize="14" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,5"/>
                                <ComboBox x:Name="DatabaseComboBox" 
                                          ItemsSource="{Binding AvailableDatabases}"
                                          SelectedItem="{Binding EditingWorkspace.SelectedDatabase}"
                                          Margin="0,0,0,15"
                                          Height="35"
                                          FontSize="14"
                                          TextElement.Foreground="#000000"
                                          ToolTip="Select the database where meeting notes will be saved">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#000000"/>
                                    </ComboBox.Resources>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="#000000"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save" 
                                            Click="OnSaveWorkspaceClicked" 
                                            Padding="15,8"
                                            Margin="0,0,10,0"
                                            Background="{DynamicResource SuccessBrush}"/>
                                    <Button Content="Cancel" 
                                            Click="OnCancelWorkspaceClicked" 
                                            Padding="15,8"
                                            Background="{DynamicResource Gray600Brush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- AI Settings -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="AI Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Local LLM Integration (LMStudio)" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,5"/>
                        
                        <TextBlock Text="This app uses LMStudio running locally for AI-powered meeting summaries. Make sure LMStudio is running on http://127.0.0.1:1234 with meta-llama-3.1-8b-instruct loaded." 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        
                        <Button Content="Test LMStudio Connection" 
                                Click="OnTestLMStudioClicked"
                                Padding="15,8"
                                Background="{DynamicResource SuccessBrush}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Call Detection Settings -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Call Detection Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="CallDetectionCheckBox" 
                                      IsChecked="{Binding IsCallDetectionEnabled}"
                                      Checked="OnCallDetectionChanged"
                                      Unchecked="OnCallDetectionChanged"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Enable automatic call detection" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Detected Apps:" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        
                        <ListBox x:Name="DetectedAppsListBox" Height="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsEnabled}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding AppName}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Status}" 
                                                   FontSize="12" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- General Settings -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="General Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="StartMinimizedCheckBox" 
                                      IsChecked="{Binding StartMinimized}"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Start minimized to system tray" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="AutoSaveCheckBox" 
                                      IsChecked="{Binding AutoSaveNotes}"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Automatically save notes during meetings" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="ShowNotificationsCheckBox" 
                                      IsChecked="{Binding ShowNotifications}"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Show desktop notifications for call detection" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Actions -->
        <Border Grid.Row="2" 
                Background="{DynamicResource SurfaceBrush}" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" 
                        Background="{DynamicResource Gray600Brush}" 
                        Foreground="White"
                        Click="OnCloseClicked" 
                        Padding="15,8"/>
            </StackPanel>
        </Border>

    </Grid>

</Window>
