<Window x:Class="MeetingNotesApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Notes - Settings" Height="700" Width="900"
        Background="{DynamicResource LightBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="{DynamicResource WhiteBrush}" Margin="0,0,15,0"/>
                <TextBlock Text="Settings" 
                           Foreground="{DynamicResource WhiteBrush}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="Manage integrations and preferences" 
                           Foreground="{DynamicResource AccentBrush}" 
                           FontSize="14" 
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>

                <!-- Notion Workspace Integrations -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Notion Workspace Integrations" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Margin="0,0,10,0"/>
                            <Button Content="Add Workspace" 
                                    Click="OnAddWorkspaceClicked" 
                                    Padding="15,8"
                                    Background="{DynamicResource SuccessBrush}"/>
                        </StackPanel>
                        
                        <TextBlock Text="Manage your Notion workspace integrations. Each workspace requires its own API key." 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- Workspace List -->
                        <ListBox x:Name="WorkspaceListBox" 
                                 Height="300" 
                                 Margin="0,0,0,15"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,10"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource LightBrush}" 
                                            CornerRadius="8" 
                                            Padding="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding WorkspaceName}" 
                                                           FontSize="16" 
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding WorkspaceId}" 
                                                           FontSize="12" 
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding SelectedDatabase.Name}" 
                                                           FontSize="12" 
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,0,0,5"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" 
                                                            Fill="{Binding StatusColor}" 
                                                            Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding StatusText}" 
                                                               FontSize="12" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="Edit" 
                                                        Click="OnEditWorkspaceClicked" 
                                                        Tag="{Binding}"
                                                        Padding="12,6"
                                                        Margin="0,0,5,0"
                                                        FontSize="12"
                                                        MinWidth="50"
                                                        Background="{DynamicResource InfoBrush}"/>
                                                <Button Content="Test" 
                                                        Click="OnTestWorkspaceClicked" 
                                                        Tag="{Binding}"
                                                        Padding="12,6"
                                                        Margin="0,0,5,0"
                                                        FontSize="12"
                                                        MinWidth="50"
                                                        Background="{DynamicResource PrimaryBrush}"/>
                                                <Button Content="Delete" 
                                                        Click="OnDeleteWorkspaceClicked" 
                                                        Tag="{Binding}"
                                                        Padding="12,6"
                                                        FontSize="12"
                                                        MinWidth="60"
                                                        Background="{DynamicResource ErrorBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Add/Edit Workspace Form -->
                        <Border Background="{DynamicResource LightBrush}" 
                                CornerRadius="8" 
                                Padding="15">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFormVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding FormTitle}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,0,0,15"/>

                                <!-- Quick Setup Guide (only shown when adding, not editing) -->
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        CornerRadius="6"
                                        Padding="12"
                                        Margin="0,0,0,15"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FormTitle}" Value="Edit Workspace">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="New to Notion integrations? Follow these steps:"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,0,10"/>

                                        <!-- Step 1 -->
                                        <StackPanel Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Step 1"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="Create an internal integration"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Margin="0,2,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                                                <Run Text="Just enter a name, pick your workspace, and click Create. "/>
                                                <Hyperlink NavigateUri="https://www.notion.so/profile/integrations/internal/form/new-integration"
                                                           RequestNavigate="OnNotionIntegrationLinkClicked"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           TextDecorations="Underline">Create Integration &#x2197;</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Step 2 -->
                                        <StackPanel Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Step 2"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="Copy your API key"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="After creating, you'll see an &quot;Internal Integration Secret&quot; — copy it and paste it into the API Key field below."
                                                       Margin="0,2,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Step 3 -->
                                        <StackPanel Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Step 3"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="Connect your integration to a database"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Margin="0,2,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                       Text="Open your meetings database in Notion (web or desktop app), then:"/>
                                            <TextBlock Margin="10,2,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                       Text="1. Click the &#x2022;&#x2022;&#x2022; menu in the top-right corner of the page"/>
                                            <TextBlock Margin="10,2,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                       Text="2. Scroll down and click &quot;+ Add connections&quot;"/>
                                            <TextBlock Margin="10,2,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                       Text="3. Search for your integration name and select it"/>
                                            <TextBlock Margin="10,2,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                       Text="4. Click Confirm, then come back here and click &quot;Fetch Databases&quot;"/>
                                            <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                                                <Run Text="Need help? "/>
                                                <Hyperlink NavigateUri="https://www.notion.com/help/add-and-manage-connections-with-the-api"
                                                           RequestNavigate="OnNotionIntegrationLinkClicked"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           TextDecorations="Underline">See Notion's guide with screenshots &#x2197;</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Already have one? -->
                                        <TextBlock FontSize="11" Margin="0,2,0,0" Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="Already have an integration? "/>
                                            <Hyperlink NavigateUri="https://www.notion.so/profile/integrations"
                                                       RequestNavigate="OnNotionIntegrationLinkClicked"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       TextDecorations="Underline">Manage Integrations &#x2197;</Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Workspace Display Name"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="A friendly name for this workspace (e.g., 'Work' or 'Personal')"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="WorkspaceNameBox"
                                         Text="{Binding EditingWorkspace.WorkspaceName}"
                                         Margin="0,0,0,15"
                                         ToolTip="This is the name you'll see when selecting where to save notes"/>
                                
                                <TextBlock Text="Notion API Key"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,2"/>
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,5"
                                           TextWrapping="Wrap">
                                    <Run Text="Paste the Internal Integration Secret from your "/>
                                    <Hyperlink NavigateUri="https://www.notion.so/profile/integrations/internal/form/new-integration"
                                               RequestNavigate="OnNotionIntegrationLinkClicked"
                                               Foreground="{DynamicResource AccentBrush}"
                                               TextDecorations="Underline">Notion integration</Hyperlink>
                                    <Run Text="."/>
                                </TextBlock>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="ApiKeyBox" Grid.Column="0"/>
                                    <Button Content="Fetch Databases" 
                                            Grid.Column="2"
                                            Click="OnFetchDatabasesClicked"
                                            Padding="15,8"
                                            Background="{DynamicResource PrimaryBrush}"
                                            ToolTip="Click to retrieve databases from Notion"/>
                                </Grid>
                                
                                <TextBlock Text="Meeting Notes Database"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="Don't see your database? In Notion, open it and click &#x2022;&#x2022;&#x2022; &#x2192; Add connections to grant access."
                                           FontSize="12"
                                           FontStyle="Italic"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,5"/>
                                <ComboBox x:Name="DatabaseComboBox" 
                                          ItemsSource="{Binding AvailableDatabases}"
                                          SelectedItem="{Binding EditingWorkspace.SelectedDatabase}"
                                          Margin="0,0,0,15"
                                          Height="35"
                                          FontSize="14"
                                          TextElement.Foreground="#000000"
                                          ToolTip="Select the database where meeting notes will be saved">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#000000"/>
                                    </ComboBox.Resources>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="#000000"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save" 
                                            Click="OnSaveWorkspaceClicked" 
                                            Padding="15,8"
                                            Margin="0,0,10,0"
                                            Background="{DynamicResource SuccessBrush}"/>
                                    <Button Content="Cancel" 
                                            Click="OnCancelWorkspaceClicked" 
                                            Padding="15,8"
                                            Background="{DynamicResource Gray600Brush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- AI Settings -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="AI Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Local LLM Integration (LMStudio)" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,5"/>
                        
                        <TextBlock Text="This app uses LMStudio running locally for AI-powered meeting summaries. Make sure LMStudio is running on http://127.0.0.1:1234 with meta-llama-3.1-8b-instruct loaded." 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        
                        <Button Content="Test LMStudio Connection" 
                                Click="OnTestLMStudioClicked"
                                Padding="15,8"
                                Background="{DynamicResource SuccessBrush}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Speaker Diarization Settings -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Speaker Diarization"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="Speaker diarization identifies who said what during meetings. After recording stops, the audio is analyzed to label each speaker's contributions. All processing happens locally on your device."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <!-- Active Segmentation Model Selector -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Active Model:"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <ComboBox x:Name="ActiveDiarizationModelComboBox"
                                      Width="280"
                                      Height="32"
                                      FontSize="13"
                                      SelectionChanged="OnActiveDiarizationModelChanged"
                                      ToolTip="Select which downloaded segmentation model to use for speaker diarization"/>
                        </StackPanel>

                        <!-- Segmentation Models List -->
                        <TextBlock Text="Segmentation Models"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl x:Name="DiarizationModelListControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource LightBrush}"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{Binding StatusColor}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Button Content="Download"
                                                        Click="OnDownloadDiarizationSegModelClicked"
                                                        Tag="{Binding ModelType}"
                                                        Padding="12,6"
                                                        FontSize="12"
                                                        MinWidth="80"
                                                        Background="{DynamicResource SuccessBrush}"
                                                        Visibility="{Binding DownloadButtonVisibility}"/>
                                                <Button Content="Delete"
                                                        Click="OnDeleteDiarizationSegModelClicked"
                                                        Tag="{Binding ModelType}"
                                                        Padding="12,6"
                                                        FontSize="12"
                                                        MinWidth="80"
                                                        Background="{DynamicResource ErrorBrush}"
                                                        Visibility="{Binding DeleteButtonVisibility}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Segmentation Download Progress -->
                        <StackPanel x:Name="DiarizationSegDownloadProgress" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock x:Name="DiarizationSegDownloadStatusText"
                                           Text="Downloading..."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Button x:Name="CancelDiarizationSegDownloadButton"
                                        Content="Cancel"
                                        Click="OnCancelDiarizationSegDownloadClicked"
                                        Padding="8,2"
                                        Margin="15,0,0,0"
                                        FontSize="11"
                                        Background="{DynamicResource Gray600Brush}"/>
                            </StackPanel>
                            <ProgressBar x:Name="DiarizationSegDownloadProgressBar"
                                         Value="0" Minimum="0" Maximum="100" Height="6"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         Background="{DynamicResource Gray300Brush}"/>
                        </StackPanel>

                        <!-- Speaker Embedding Model -->
                        <TextBlock Text="Speaker Embedding Model"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,15,0,5"/>

                        <TextBlock Text="Required for all diarization. Identifies unique speakers by voice characteristics."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="3D-Speaker CampPlus English (~28 MB)"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Ellipse x:Name="EmbeddingModelStatusDot" Width="8" Height="8" Fill="Gray" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="EmbeddingModelStatusText"
                                       Text="Checking..."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                            <Button x:Name="DownloadEmbeddingModelButton"
                                    Content="Download"
                                    Click="OnDownloadEmbeddingModelClicked"
                                    Padding="12,6"
                                    FontSize="12"
                                    Margin="0,0,10,0"
                                    Background="{DynamicResource SuccessBrush}"/>
                            <Button x:Name="DeleteEmbeddingModelButton"
                                    Content="Delete"
                                    Click="OnDeleteEmbeddingModelClicked"
                                    Padding="12,6"
                                    FontSize="12"
                                    Background="{DynamicResource ErrorBrush}"
                                    Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Embedding Download Progress -->
                        <StackPanel x:Name="EmbeddingDownloadProgress" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock x:Name="EmbeddingDownloadStatusText"
                                       Text="Downloading..."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,5"/>
                            <ProgressBar x:Name="EmbeddingDownloadProgressBar"
                                         Value="0" Minimum="0" Maximum="100" Height="6"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         Background="{DynamicResource Gray300Brush}"/>
                        </StackPanel>

                        <!-- Advanced Settings -->
                        <TextBlock Text="Advanced Settings"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Number of Speakers:" VerticalAlignment="Center" FontSize="12"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="DiarizationNumSpeakersBox"
                                         Text="-1" Width="60" Padding="4,2"
                                         ToolTip="-1 = auto-detect. Set to a positive number to force a specific speaker count."/>
                                <TextBlock Text="(-1 = auto-detect)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Clustering Threshold:" VerticalAlignment="Center" FontSize="12"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="DiarizationThresholdBox"
                                         Text="0.5" Width="60" Padding="4,2"
                                         ToolTip="Lower = more speakers detected. Higher = fewer speakers. Range: 0.0 - 1.0"/>
                                <TextBlock Text="(0.0 - 1.0, lower = more speakers)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Speech Recognition (ASR) Settings -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Speech Recognition"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="Speech recognition converts meeting audio into text. Multiple models are available — larger models are more accurate but slower. All processing happens locally on your device."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <!-- Active Model Selector -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Active Model:"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <ComboBox x:Name="ActiveASRModelComboBox"
                                      Width="280"
                                      Height="32"
                                      FontSize="13"
                                      SelectionChanged="OnActiveASRModelChanged"
                                      ToolTip="Select which downloaded model to use for transcription"/>
                        </StackPanel>

                        <!-- Available Models List -->
                        <TextBlock Text="Available Models"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl x:Name="ASRModelListControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource LightBrush}"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{Binding StatusColor}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Button Content="Download"
                                                        Click="OnDownloadASRModelClicked"
                                                        Tag="{Binding ModelType}"
                                                        Padding="12,6"
                                                        FontSize="12"
                                                        MinWidth="80"
                                                        Background="{DynamicResource SuccessBrush}"
                                                        Visibility="{Binding DownloadButtonVisibility}"/>
                                                <Button Content="Delete"
                                                        Click="OnDeleteASRModelClicked"
                                                        Tag="{Binding ModelType}"
                                                        Padding="12,6"
                                                        FontSize="12"
                                                        MinWidth="80"
                                                        Background="{DynamicResource ErrorBrush}"
                                                        Visibility="{Binding DeleteButtonVisibility}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Download Progress -->
                        <StackPanel x:Name="ASRDownloadProgress" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock x:Name="ASRDownloadStatusText"
                                           Text="Downloading..."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Button x:Name="CancelASRDownloadButton"
                                        Content="Cancel"
                                        Click="OnCancelASRDownloadClicked"
                                        Padding="8,2"
                                        Margin="15,0,0,0"
                                        FontSize="11"
                                        Background="{DynamicResource Gray600Brush}"/>
                            </StackPanel>
                            <ProgressBar x:Name="ASRDownloadProgressBar"
                                         Value="0" Minimum="0" Maximum="100" Height="6"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         Background="{DynamicResource Gray300Brush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Call Detection Settings -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Call Detection Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="CallDetectionCheckBox" 
                                      IsChecked="{Binding IsCallDetectionEnabled}"
                                      Checked="OnCallDetectionChanged"
                                      Unchecked="OnCallDetectionChanged"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Enable automatic call detection" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Detected Apps:" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        
                        <ListBox x:Name="DetectedAppsListBox" Height="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsEnabled}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding AppName}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Status}" 
                                                   FontSize="12" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- General Settings -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="10" 
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="General Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="StartMinimizedCheckBox" 
                                      IsChecked="{Binding StartMinimized}"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Start minimized to system tray" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="AutoSaveCheckBox" 
                                      IsChecked="{Binding AutoSaveNotes}"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Automatically save notes during meetings" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="ShowNotificationsCheckBox" 
                                      IsChecked="{Binding ShowNotifications}"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="Show desktop notifications for call detection" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Actions -->
        <Border Grid.Row="2" 
                Background="{DynamicResource SurfaceBrush}" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" 
                        Background="{DynamicResource Gray600Brush}" 
                        Foreground="White"
                        Click="OnCloseClicked" 
                        Padding="15,8"/>
            </StackPanel>
        </Border>

    </Grid>

</Window>
